// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}


model Company {
  id          String        @id @default(uuid())
  name        String        @unique
  domain      String?       @unique
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?
  status      CompanyStatus
  tier        TIER          @default(BASIC)

  departments Department[]  @relation("CompanyToDepartment")
  jobs        Job[]         @relation("CompanyToJob")
  pipeline    Pipeline[]    @relation("CompanyToPipeline")
  offers      Offer[]       @relation("CompanyToOffer")
  hrContacts  HRContact[]
}

model HRContact {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String?
  designation HRDesignation
  linkedin    String?
  createdAt   DateTime @default(now())

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
}

model User {
  id            String         @id @default(uuid())

  student       Student?
  ic            IC?

  email         String         @unique
  password      String
  firstName     String?
  lastName      String?

  roleId        String?
  role          Role?          @relation(fields: [roleId], references: [id])

  isActive      Boolean        @default(true)
  phone         String?

  createdAt     DateTime       @default(now())
  deletedAt     DateTime?

  notifications Notification[] @relation("NotificationToUser")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles       RolePermission[]
}

model RolePermission {
  id           String      @id @default(uuid())
  roleId       String
  permissionId String

  role         Role        @relation(fields: [roleId], references: [id])
  permission   Permission  @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model IC {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Department {
  id        String   @id @default(uuid())
  companyId String

  name      String
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation("CompanyToDepartment", fields: [companyId], references: [id])
  jobs      Job[]    @relation("DepartmentToJob")
  batches   Batch[]
  applicationForms ApplicationForm[]
}


model Job {
  id             String         @id @default(uuid())
  companyId      String
  title          String
  slug           String?        @unique
  description    String?

  departmentId   String?

  location       String?

  employmentType EmploymentType @default(FULL_TIME)
  workMode       String 
  ctc            String?

  minimumCGPA    Float?
  passingYear    Int?
  applicationDeadline DateTime?

  additionalDetails Json?

  isOpen         Boolean        @default(true)
  status         jobStatus      @default(ACTIVE)

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  openAt         DateTime       @default(now())
  closeAt        DateTime

  role           String
  tier           TIER           @default(BASIC)

  google_chat    Boolean        @default(false)
  email          Boolean        @default(false)

  company        Company        @relation("CompanyToJob", fields: [companyId], references: [id])
  department     Department?    @relation("DepartmentToJob", fields: [departmentId], references: [id])

  applications   Application[]  @relation("ApplicationToJob")
  offers         Offer[]
  batches        Batch[]
  applicationForms ApplicationForm[] @relation("JobApplicationForm")
}

model Batch {
  id        String   @id @default(uuid())
  departmentId String

  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department        Department        @relation(fields: [departmentId], references: [id])
  googleChatConfigs GoogleChatConfig[]
  jobs              Job[]
}

model GoogleChatConfig {
  id        String   @id @default(uuid())
  batchId   String

  spaceId   String
  key       String
  token     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch Batch @relation(fields: [batchId], references: [id])

  @@unique([batchId, spaceId])
}

model Student {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])

  enrollment   String
  address      String
  registration String
  branch       String
  email        String?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  applications Application[]
}

model Application {
  id         String            @id @default(uuid())
  studentId  String
  jobId      String
  pipelineId String?
  stageId    String?
  status     ApplicationStatus @default(APPLIED)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?
  metadata   Json?

  student    Student   @relation(fields: [studentId], references: [id])
  job        Job       @relation("ApplicationToJob", fields: [jobId], references: [id])
  pipeline   Pipeline? @relation(fields: [pipelineId], references: [id])
  stage      Stage?    @relation(fields: [stageId], references: [id])

  @@unique([studentId, jobId])

  offers Offer[]
}

model Pipeline {
  id        String   @id @default(uuid())
  companyId String
  name      String
  createdAt DateTime @default(now())
  deletedAt DateTime?

  company      Company      @relation("CompanyToPipeline", fields: [companyId], references: [id])
  stages       Stage[]
  applications Application[]
}

model Stage {
  id         String   @id @default(uuid())
  name       String
  sortOrder  Int
  pipelineId String
  createdAt  DateTime @default(now())

  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id])
  applications Application[]
}

model Offer {
  id            String      @id @default(uuid())
  applicationId String
  companyId     String
  status        OfferStatus @default(DRAFT)
  sentAt        DateTime?
  signedAt      DateTime?
  declinedAt    DateTime?
  declineReason String?
  sentById      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  jobId         String

  job         Job         @relation(fields: [jobId], references: [id])
  company     Company     @relation("CompanyToOffer", fields: [companyId], references: [id])
  application Application @relation(fields: [applicationId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  payload   Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User?    @relation("NotificationToUser", fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

model Activity {
  id            String   @id @default(uuid())
  companyId     String
  type          String
  body          String?
  userId        String?
  applicationId String?
  metadata      Json?
  projectId     String?
  createdAt     DateTime @default(now())
}


model ApplicationForm {
  id        String  @id @default(uuid())
  title     String
  isDefault Boolean @default(false)

  sections FormSection[]

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  jobs Job[] @relation("JobApplicationForm")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FormSection {
  id          String  @id @default(uuid())
  title       String
  order       Int
  description String?

  formId String
  form   ApplicationForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  questions FormQuestion[]
}

model FormQuestion {
  id          String       @id @default(uuid())
  label       String
  type        QuestionType
  order       Int
  required    Boolean      @default(false)
  isPrivate   Boolean      @default(false)
  description String?
  systemNote  String?

  sectionId String
  section   FormSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  options QuestionOption[]
}

model QuestionOption {
  id    String @id @default(uuid())
  label String
  value String

  questionId String
  question   FormQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  EMAIL
  PHONE
  YES_NO
  CHECKBOX
  MULTIPLE_CHOICE
  DATE
  FILE_UPLOAD
  URL
}


enum CompanyStatus {
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  DRIVE_COMPLETED
  OFFER_RELEASED
  ON_HOLD
  BLACKLISTED
}

enum TIER {
  BASIC
  STANDARD
  DREAM
}

enum HRDesignation {
  HR
  TALENT_ACQUISITION
  RECRUITER
  SENIOR_RECRUITER
  HR_MANAGER
  HR_HEAD
  CAMPUS_RECRUITER
  TECH_RECRUITER
  OTHER
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  PHONE_SCREEN
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  ARCHIVED
}

enum jobStatus {
  ACTIVE
  CLOSED
  DRAFT
  PAUSED
  ARCHIVED
}

enum OfferStatus {
  DRAFT
  SENT
  SIGNED
  DECLINED
  HIRED
  WITHDRAWN
  CANCELED
}